# x402-buy-spl-token — minimal env for quick local run (no Postgres)

# Server
LISTEN_ADDR=0.0.0.0:8080

# Solana RPC (devnet example)
RPC_URL=https://api.devnet.solana.com

# pr402 facilitator (origin + /api/v1/facilitator)
X402_FACILITATOR_URL=https://your-pr402-host/api/v1/facilitator

# x402 network (CAIP-2)
X402_NETWORK=solana:EtWTRABZaYq6iMfeYKouRu166VU2xqa1

# sla-escrow escrow PDA for USDC (accepts[].payTo) — NOT the merchant wallet
X402_PAY_TO=YourEscrowPdaBase58

# Merchant payout identity (extra.merchantWallet; FundPayment.seller when beneficiary unset)
# Required. Alias: MERCHANT_WALLET. Must differ from X402_PAY_TO.
X402_MERCHANT_WALLET=YourMerchantCollectionWalletBase58

# Optional: overrides merchantWallet for FundPayment.seller / ReleasePayment (pr402 prefers this)
# X402_BENEFICIARY=YourBeneficiaryWalletBase58

# Merchant signer — must match fund-payment payout (beneficiary ?? merchantWallet).
# Signs SubmitDelivery only. Hot or cold wallet is operator choice.
MERCHANT_SIGNER_KEYPAIR_BASE58=YourMerchantSignerBase58SecretKey

# Oracle allow-list for sla-escrow builds (JSON array or comma-separated)
ORACLE_AUTHORITIES=["YourOraclePubkeyBase58"]

# Delivery hot key (signs SPL TransferChecked only) — distinct from merchant payout
SELLER_KEYPAIR_BASE58=YourDeliveryHotKeyBase58SecretKey

# Token catalog — unit list prices (per quantity=1). Session totals computed server-side.
BUY_SPL_TOKEN_CATALOG_JSON='[{"mint":"5bpyckh5YBVG5fB63PSm4BGPjD5sw1TwBtU5GGd9VRRP","decimals":6,"price_usdc_ui":"0.42","deliver_amount_ui":"1000","name":"merry-xmas"}]'

# Evidence registry (required at cold start for paid-path SLA + evidence upload)
REGISTRY_BASE_URL=https://your-registry-host
REGISTRY_BEARER_TOKEN=your-token

# Example unpaid URL (quantity defaults to 1):
# GET /api/v1/buy-spl-token?token=5bpyckh5YBVG5fB63PSm4BGPjD5sw1TwBtU5GGd9VRRP&quantity=3&recipient_owner=...&buyer_nonce=...

# Optional: override 402 resource URL
# X402_RESOURCE_URL=https://your-host/api/v1/buy-spl-token

# --- Optional Postgres (production idempotency + parameters table) ---
# DATABASE_ENABLED=true
# DATABASE_URL=postgres://user:pass@localhost/x402_buy_spl_token

# SLA-Escrow program id override (defaults to mainnet id)
# SLA_ESCROW_PROGRAM_ID=SEscZ6n23pVak34xipBKoGCikHUj3w6XPNyty4rHprJ

# Logging
# RUST_LOG=info,x402_buy_spl_token=debug
